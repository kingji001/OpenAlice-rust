{
  "name": "02-three-commits-with-rejection",
  "description": "Three sequential commits; second push has one rejection.",
  "steps": [
    { "op": "stagePlaceOrder", "fixture": "parity/fixtures/operations/placeOrder/case-buy-mkt-day-plain-default-001.json" },
    { "op": "commit", "message": "First buy" },
    { "op": "push", "stubResults": [
      { "action": "placeOrder", "success": true, "orderId": "mock-1", "status": "filled", "filledQty": "100", "filledPrice": "100" }
    ]},
    { "op": "stagePlaceOrder", "fixture": "parity/fixtures/operations/placeOrder/case-sell-mkt-day-plain-default-361.json" },
    { "op": "commit", "message": "Sell attempt (will be rejected)" },
    { "op": "push", "stubResults": [
      { "action": "placeOrder", "success": false, "orderId": "mock-2", "status": "rejected", "error": "Insufficient margin" }
    ]},
    { "op": "stagePlaceOrder", "fixture": "parity/fixtures/operations/placeOrder/case-buy-lmt-day-plain-default-073.json" },
    { "op": "commit", "message": "Limit buy after failed sell" },
    { "op": "push", "stubResults": [
      { "action": "placeOrder", "success": true, "orderId": "mock-3", "status": "filled", "filledQty": "100", "filledPrice": "150.5" }
    ]}
  ]
}
