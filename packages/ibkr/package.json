{
  "name": "@traderalice/ibkr",
  "version": "0.1.0",
  "description": "TypeScript port of IBKR TWS API v10.44.01",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TraderAlice/OpenAlice.git",
    "directory": "packages/ibkr"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@traderalice/ibkr-client": "workspace:*",
    "@traderalice/ibkr-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0"
}
